{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:vercel",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/admin/ingest/cron",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/admin/gamification/recompute",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/admin/project-progress/refresh",
      "schedule": "17 7 * * *"
    }
  ],
  "outputDirectory": "apps/web/.next"
}
