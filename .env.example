# Coordinator (apps/web)
DATABASE_URL=postgres://user:pass@host/db
# Public-launch signing uses Ed25519: coordinator keeps private key, workers receive public key.
PACKET_SIGNING_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nreplace-with-ed25519-private-key\n-----END PRIVATE KEY-----
PACKET_SIGNING_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nreplace-with-ed25519-public-key\n-----END PUBLIC KEY-----
PACKET_SIGNING_KEY_ID=opencause-alpha-1
# Private-alpha/local fallback only. Prefer PACKET_SIGNING_PRIVATE_KEY/PUBLIC_KEY for hosted deployments.
SIGNING_SECRET=replace-with-long-random-secret
ADMIN_API_KEY=replace-with-admin-token
ADMIN_UI_PASSWORD=replace-with-private-alpha-admin-password
OPENCAUSE_LOCAL_DEV=false
OPENCAUSE_HOSTED=false
ENABLE_CRON_INGEST=false
NODE_ENROLLMENT_CODES=replace-with-private-alpha-code,replace-with-second-code
CRON_SECRET=replace-with-cron-token
NCBI_EMAIL=you@example.com
NCBI_API_KEY=
DEFAULT_PACKET_EXTRACTOR=local-llm-v1
ALLOW_MOCK_RESULTS=false
CRON_PUBMED_QUERY=cancer biomarker response resistance
CRON_PUBMED_RETMAX=12
CRON_PMC_OA_QUERY=cancer biomarker response resistance
CRON_PMC_OA_RETMAX=6

# Worker (apps/worker)
COORDINATOR_URL=http://localhost:3000
PACKET_SIGNING_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nreplace-with-ed25519-public-key\n-----END PUBLIC KEY-----
PACKET_SIGNING_KEY_ID=opencause-alpha-1
EXTRACTOR_MODE=local-llm
ALLOW_MOCK_EXTRACTOR=false
LOCAL_LLM_ENDPOINT=http://127.0.0.1:11434
LOCAL_LLM_MODEL=llama3.2:3b
LOCAL_LLM_TIMEOUT_MS=45000
IDLE_MODE=user-and-cpu
MIN_IDLE_SECONDS=120
MAX_CPU_PERCENT=35

# Rate limits (per minute; lightweight in-process defaults, suitable for private alpha / serverless best effort)
RATE_LIMIT_PUBLIC_API_PER_MINUTE=120
RATE_LIMIT_ADMIN_API_PER_MINUTE=60
RATE_LIMIT_ADMIN_INGEST_PER_MINUTE=10
RATE_LIMIT_WORKER_CONTROL_PER_MINUTE=30
RATE_LIMIT_NODE_REGISTER_PER_MINUTE=5
RATE_LIMIT_NODE_HEARTBEAT_PER_MINUTE=60
RATE_LIMIT_WORK_CLAIM_PER_MINUTE=30
RATE_LIMIT_WORK_SUBMIT_PER_MINUTE=30

# Public volunteer self-serve enrollment (requires abuse challenge before broad public use)
ENABLE_PUBLIC_VOLUNTEER_ENROLLMENT=false
TURNSTILE_SITE_KEY=replace-with-cloudflare-turnstile-site-key
TURNSTILE_SECRET_KEY=replace-with-cloudflare-turnstile-secret-key

# Public worker download links (leave unset until artifact/checksum/release notes are ready)
NEXT_PUBLIC_WORKER_DOWNLOAD_STAGE=prototype
NEXT_PUBLIC_WINDOWS_WORKER_DOWNLOAD_URL=
NEXT_PUBLIC_WINDOWS_WORKER_CHECKSUM_URL=
NEXT_PUBLIC_WINDOWS_WORKER_RELEASE_NOTES_URL=

# Dangerous private-alpha cleanup switch; keep false in real production
ENABLE_ADMIN_TEST_RESET=false
# Use Postgres-backed rate limits in hosted mode; set false only for local debugging
OPENCAUSE_DB_RATE_LIMITS=true
