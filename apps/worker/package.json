  },
  "dependencies": {
    "@opencause/shared": "file:../../packages/shared",
    "tsx": "^4.19.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2",
    "vitest": "^4.1.5"
  }
}
