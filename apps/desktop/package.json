{
  "name": "@opencause/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/electron-main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-static.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "electron:dev": "npm run build && electron dist/electron-main.js",
    "package:plan": "node dist/index.js package-plan",
    "package:win:unsigned": "npm run build && electron-builder --config electron-builder.json --win --x64",
    "package:dir": "npm run build && electron-builder --config electron-builder.json --dir"
  },
  "dependencies": {
    "@opencause/shared": "file:../../packages/shared"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.5"
  }
}
