{
  "appId": "ai.appassist.opencause.compute.worker",
  "productName": "OpenCause Compute Worker",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "../worker/dist",
      "to": "worker/dist"
    },
    {
      "from": "../worker/package.json",
      "to": "worker/package.json"
    },
    {
      "from": "../../packages/shared/dist",
      "to": "worker/node_modules/@opencause/shared/dist"
    },
    {
      "from": "../../packages/shared/package.json",
      "to": "worker/node_modules/@opencause/shared/package.json"
    },
    {
      "from": "../../node_modules/zod",
      "to": "worker/node_modules/zod"
    },
    {
      "from": "static/config",
      "to": "worker/config"
    },
    {
      "from": "assets",
      "to": "assets"
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "signAndEditExecutable": false,
    "icon": "assets/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "OpenCause Compute Worker"
  },
  "mac": {
    "target": [
      "dir"
    ],
    "identity": null
  },
  "linux": {
    "target": [
      "dir"
    ]
  }
}
