{
  "name": "opencause-compute",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @opencause/web",
    "dev:worker": "npm run dev -w @opencause/worker",
    "setup": "npm install && npm run build && npm run typecheck && npm run test",
    "start:web": "npm run start -w @opencause/web",
    "start:worker:once": "npm run start -w @opencause/worker -- run-once --server http://localhost:3000",
    "start:worker:loop": "npm run start -w @opencause/worker -- loop --server http://localhost:3000 --interval-ms 5000",
    "start:up": "node scripts/up.mjs",
    "service:install:unix": "sh scripts/service-install-unix.sh",
    "service:start:unix": "sh scripts/service-start-unix.sh",
    "service:stop:unix": "sh scripts/service-stop-unix.sh",
    "service:status:unix": "sh scripts/service-status-unix.sh",
    "service:uninstall:unix": "sh scripts/service-uninstall-unix.sh",
    "service:install:windows": "powershell -ExecutionPolicy Bypass -File scripts/service-install-windows.ps1",
    "service:start:windows": "powershell -ExecutionPolicy Bypass -File scripts/service-start-windows.ps1",
    "service:stop:windows": "powershell -ExecutionPolicy Bypass -File scripts/service-stop-windows.ps1",
    "service:status:windows": "powershell -ExecutionPolicy Bypass -File scripts/service-status-windows.ps1",
    "service:uninstall:windows": "powershell -ExecutionPolicy Bypass -File scripts/service-uninstall-windows.ps1",
    "release:install:unix": "sh scripts/install-unix.sh",
    "release:install:windows": "powershell -ExecutionPolicy Bypass -File scripts/install-windows.ps1",
    "demo:up": "node scripts/demo-up.mjs",
    "demo:web": "npm run dev:web",
    "demo:seed": "node scripts/seed-demo.mjs",
    "demo:worker:once": "npm run dev -w @opencause/worker -- run-once --server http://localhost:3000",
    "demo:worker:loop": "npm run dev -w @opencause/worker -- loop --server http://localhost:3000 --interval-ms 5000",
    "build": "npm run build -w @opencause/shared && npm run build -w @opencause/web && npm run build -w @opencause/worker",
    "typecheck": "npm run typecheck -w @opencause/shared && npm run typecheck -w @opencause/web && npm run typecheck -w @opencause/worker",
    "test": "npm run test -w @opencause/shared && npm run test -w @opencause/web && npm run test -w @opencause/worker"
  }
}
